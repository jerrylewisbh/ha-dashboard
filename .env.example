# Copy this file to .env and fill in your values.
# .env and .env.development are gitignored — never commit real credentials.

# Folder created under /config/www/ on your HA instance
VITE_FOLDER_NAME=ha-dashboard

# Home Assistant instance URL (local or Nabu Casa remote)
# Note: typescript sync (npm run sync) requires a https URL
VITE_HA_URL=http://192.168.1.x:8123

# SSH credentials used by npm run deploy
# See: https://shannonhochkins.github.io/ha-component-kit/?path=/docs/introduction-deploying--docs#retrieving-ssh-credentials
VITE_SSH_USERNAME=root
VITE_SSH_PASSWORD=your-ssh-password
VITE_SSH_HOSTNAME=192.168.1.x

# Music Assistant long-lived token (generate from MASS admin UI)
VITE_MASS_TOKEN=your-mass-token

# Music Assistant party/join URL
VITE_MASS_PARTY_URL=http://192.168.1.x:8095/?join=XXXXXX
